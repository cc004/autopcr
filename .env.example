# AutoPCR Docker Configuration
# Copy this file to .env and modify as needed
# cp .env.example .env

# ---- Server Settings ----

# HTTP server bind address (0.0.0.0 = all interfaces)
AUTOPCR_SERVER_HOST=0.0.0.0

# HTTP server port
AUTOPCR_SERVER_PORT=13200

# Enable debug logging (true/false)
AUTOPCR_SERVER_DEBUG_LOG=false

# Allow new user registration (true/false)
AUTOPCR_SERVER_ALLOW_REGISTER=true

# Superuser QQ number (has admin privileges, leave empty to disable)
AUTOPCR_SERVER_SUPERUSER=

# ---- Public Access (for QQ bot message links) ----

# Public IP or domain for QQ bot to send access links
# e.g., "example.com" or "1.2.3.4:13200"
# Leave empty to auto-detect
AUTOPCR_PUBLIC_ADDRESS=

# Use HTTPS for public access links (true/false)
AUTOPCR_USE_HTTPS=false

# ---- Taiwan Server Settings ----

# Fallback client version for TW accounts. This may need to be updated when
# the official client is upgraded. A per-account app_version takes priority.
AUTOPCR_TW_APP_VERSION=5.7.0

# Bootstrap HTTP resource version. It is independent from master_tw.db; a
# successful response's required_res_ver keeps it synchronized afterward.
AUTOPCR_TW_RES_VERSION=00500030

# Runtime versions extracted from the current TW Android client.
AUTOPCR_TW_UNITY_VERSION=6000.0.58f2
AUTOPCR_TW_CURL_VERSION=8.10.1-DEV
# 默认绕过 Windows/容器系统代理直连台服；确实需要系统代理时改为 true
AUTOPCR_TW_USE_SYSTEM_PROXY=false

# Optional stable device-id override. Leave empty to derive it from each
# account's UDID, avoiding a shared identifier across installations.
AUTOPCR_TW_DEVICE_ID=

# Optional TW API root override. Normally leave empty so server routing is
# selected automatically from TW_SERVER_ID.
AUTOPCR_TW_API_ROOT=

# Prefer the official So-net manifests and content-addressed AssetBundle pool.
# UnityPy >= 1.25 is required; current Unity 6000 bundles need no decrypt key.
# First extraction can peak near 410 MiB by itself; reserve at least 1 GiB for
# the full service, or set this to false on low-memory hosts to use the mirror.
AUTOPCR_TW_OFFICIAL_DB=true
AUTOPCR_TW_RESOURCE_BASE_URL=https://img-pc.so-net.tw

# The database is checked hourly. These GitHub URLs are a decoded fallback
# only; official and mirror caches use separate directories.
AUTOPCR_TW_DB_CHECK_INTERVAL=3600
AUTOPCR_TW_DB_VERSION_URL=https://raw.githubusercontent.com/Expugn/priconne-database/master/version.json
AUTOPCR_TW_DB_URL=https://raw.githubusercontent.com/Expugn/priconne-database/master/master_tw.db

# ---- Docker Settings ----

# Host port to map (change if 13200 is occupied)
HOST_PORT=13200

# Container timezone
TZ=Asia/Shanghai

# Restart policy: no | always | on-failure | unless-stopped
RESTART_POLICY=unless-stopped
